{
  "name": "conatus-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:turbo": "next dev --turbopack --hostname 127.0.0.1",
    "dev:clean": "rm -rf .next && next dev --hostname 127.0.0.1",
    "dev:fresh": "for p in 3000 3001 3002 3003; do lsof -ti :$p 2>/dev/null | xargs kill -9 2>/dev/null || true; done; rm -rf .next node_modules/.cache && next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate:hardware-gif": "node scripts/generate-hardware-robot-gif.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "next": "^15.3.3",
    "next-intl": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "ffmpeg-static": "^5.3.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
