# Vercel / production ortam değişkenleri (Settings → Environment Variables)
# Bu dosyayı kopyalamayın; değerleri yalnızca hosting panelinde tanımlayın.

# Resend — iletişim formu e-postası (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx

# Formun gönderileceği adres (opsiyonel; yoksa siteConfig.email kullanılır)
CONTACT_TO_EMAIL=info@conatus.com.tr

# Resend’de doğrulanmış gönderen (opsiyonel)
RESEND_FROM_EMAIL=CONATUS Website <noreply@conatus.com.tr>

# Supabase — iletişim formu kayıtları (https://supabase.com)
# Settings → API: Project URL + service_role key (anon değil)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx
